# Token de integración de Notion (obténlo en https://www.notion.so/my-integrations)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# IDs de las bases de datos de Notion
# Base de datos de Materias
NOTION_DB_MATERIAS=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Base de datos de Notas/Calificaciones
NOTION_DB_NOTAS=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Base de datos de Tareas
NOTION_DB_TAREAS=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Base de datos de Examenes
NOTION_DB_EXAMENES=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# IDs de paginas de Notion con codigos (separados por coma)
NOTION_PAGE_IDS=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx,yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
